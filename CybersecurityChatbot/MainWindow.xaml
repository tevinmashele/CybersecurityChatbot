<Window x:Class="CybersecurityChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAA - Cybersecurity Awareness Assistant"
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#0A1929">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="#1A2A4A" Padding="15" BorderBrush="#00D4FF" BorderThickness="0,0,0,2">
            <TextBlock Text="CAA - Cybersecurity Awareness Assistant" 
                       Foreground="#00D4FF" 
                       FontSize="20" 
                       FontWeight="Bold"
                       TextAlignment="Center"/>
        </Border>

        <!-- CHAT DISPLAY -->
        <Border Grid.Row="1" Background="#0A1929" Padding="10">
            <ScrollViewer x:Name="ChatScrollViewer" 
                          VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="ChatDisplay" 
                           TextWrapping="Wrap" 
                           Foreground="#E0E0E0"
                           FontSize="14"
                           LineHeight="25"/>
            </ScrollViewer>
        </Border>

        <!-- INPUT SECTION -->
        <Border Grid.Row="2" Background="#1A2A4A" Padding="15" BorderBrush="#00D4FF" BorderThickness="0,2,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInputBox" 
                         Grid.Column="0"
                         Background="#0A1929"
                         Foreground="White"
                         BorderBrush="#00D4FF"
                         BorderThickness="1"
                         Padding="12"
                         FontSize="14"
                         KeyDown="UserInputBox_KeyDown"/>

                <Button x:Name="SendButton" 
                        Grid.Column="1"
                        Content="SEND"
                        Background="#00D4FF"
                        Foreground="#0A1929"
                        Width="80"
                        Height="40"
                        Margin="10,0,0,0"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>